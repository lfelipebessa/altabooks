      ],
      "credentials": {
        "supabaseApi": {
          "id": "TODO_SUPABASE_CREDENTIAL_ID",
          "name": "Supabase service_role"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "update public.metadados_jobs set updated_at = now() where id = '{{ $('Generate XLSX').first().json.job_id }}'::uuid;",
        "options": {}
      },
      "id": "node-touch-updated",
      "name": "Touch updated_at",
      "type": "n8n-nodes-base.postgres",
