      ],
      "credentials": {
        "postgres": {
          "id": "TODO_POSTGRES_CREDENTIAL_ID",
          "name": "Supabase Postgres (service_role)"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"url\": \"https://tddolcrzmczvoqxkajic.supabase.co/storage/v1{{ $('Sign Download URL').first().json.signedURL }}\"\n}",
        "options": {}
      },
      "id": "node-respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1780,
        300
      ]
    }
  ],
